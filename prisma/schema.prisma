// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Genre {
  KOSMOS
  ALAM
  ROMANCE
  HOROR
  KONSPIRASI
}

enum StoryStatus {
  DRAFT
  PUBLISHED
}

enum ReadingMode {
  LIGHT
  DARK
  SEPIA
}

model Story {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  tagline       String?
  synopsis      String       @db.Text
  genre         Genre
  coverImageUrl String?
  coverPrompt   String?
  status        StoryStatus  @default(DRAFT)
  viewCount     Int          @default(0)
  likeCount     Int          @default(0)
  chapterCount  Int          @default(0)
  totalReadTime Int          @default(0) // in minutes
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publishedAt   DateTime?

  chapters      Chapter[]
  readingProgress ReadingProgress[]
  bookmarks     Bookmark[]
  likes         Like[]
  comments      Comment[]

  @@index([genre])
  @@index([status])
  @@index([createdAt])
  @@index([slug])
}

model Chapter {
  id            String   @id @default(cuid())
  storyId       String
  chapterNumber Int
  title         String
  content       String   @db.Text
  readTimeMinutes Int    @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  readingProgress ReadingProgress[]
  comments      Comment[]
  likes         Like[]

  @@unique([storyId, chapterNumber])
  @@index([storyId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  readingProgress ReadingProgress[]
  bookmarks     Bookmark[]
  likes         Like[]
  comments      Comment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ReadingProgress {
  id            String   @id @default(cuid())
  userId        String
  storyId       String
  chapterId     String
  lastPosition  Float    @default(0) // scroll percentage 0-100
  currentChapter Int     @default(1)
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  storyId   String?
  chapterId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@unique([userId, chapterId])
  @@index([userId])
  @@index([storyId])
  @@index([chapterId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  storyId   String?
  chapterId String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([storyId])
  @@index([chapterId])
}

model GenreSettings {
  id        String   @id @default(cuid())
  genre     Genre    @unique
  accentColor String // hex color for genre accent
  bgPattern String?  // subtle background pattern identifier
  particleType String? // ambient particle type for reader
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}